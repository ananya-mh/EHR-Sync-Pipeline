# Database
EHR_DB_HOST=postgres
EHR_DB_PORT=5432
EHR_DB_NAME=ehr_db
EHR_DB_USER=postgres
EHR_DB_PASSWORD=changeme
EHR_DB_POOL_MIN_SIZE=2
EHR_DB_POOL_MAX_SIZE=10
EHR_DB_POOL_MAX_IDLE=300.0

# Kafka
EHR_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
EHR_KAFKA_CONSUMER_GROUP_PREFIX=ehr-pipeline
EHR_KAFKA_DLQ_TOPIC=ehr.dlq
EHR_KAFKA_MAX_RETRIES=3

# API
EHR_API_HOST=0.0.0.0
EHR_API_PORT=8000

# Logging
EHR_LOG_LEVEL=INFO
EHR_LOG_FORMAT=json
